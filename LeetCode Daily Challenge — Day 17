from collections import deque

class Solution:
    def __init__(self):
        self.directions = [(1,0),(-1,0),(0,1),(0,-1)]

    def check(self, dist, sf):
        n = self.n

        if dist[0][0] < sf:
            return False

        q = deque([(0,0)])
        vis = [[False]*n for _ in range(n)]
        vis[0][0] = True

        while q:
            x,y = q.popleft()

            if x==n-1 and y==n-1:
                return True

            for dx,dy in self.directions:
                nx=x+dx
                ny=y+dy

                if (0<=nx<n and
                    0<=ny<n and
                    not vis[nx][ny] and
                    dist[nx][ny]>=sf):

                    vis[nx][ny]=True
                    q.append((nx,ny))

        return False

    def maximumSafenessFactor(self, grid):

        self.n=len(grid)
        n=self.n

        dist=[[-1]*n for _ in range(n)]
        vis=[[False]*n for _ in range(n)]

        q=deque()

        for i in range(n):
            for j in range(n):
                if grid[i][j]:
                    q.append((i,j))
                    vis[i][j]=True

        level=0

        while q:

            for _ in range(len(q)):
                x,y=q.popleft()

                dist[x][y]=level

                for dx,dy in self.directions:

                    nx=x+dx
                    ny=y+dy

                    if (0<=nx<n and
                        0<=ny<n and
                        not vis[nx][ny]):

                        vis[nx][ny]=True
                        q.append((nx,ny))

            level+=1

        left=0
        right=400
        ans=0

        while left<=right:

            mid=(left+right)//2

            if self.check(dist,mid):
                ans=mid
                left=mid+1
            else:
                right=mid-1

        return ans


