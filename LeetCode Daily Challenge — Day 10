## ⚡ Solution 2: Optimal (Matrix Exponentiation)

### Code
```python
class Solution:
    MOD = 1000000007

    def multiply(self, A, B):
        """
        Matrix Multiplication: C = A × B
        C[i][j] = Σ A[i][k] × B[k][j]
        """
        n = len(A)
        C = [[0] * n for _ in range(n)]  # Result matrix

        for i in range(n):
            for k in range(n):
                if A[i][k] == 0: continue  # Skip zero rows (optimization)
                for j in range(n):
                    if B[k][j] == 0: continue  # Skip zero cols (optimization)
                    C[i][j] = (C[i][j] + A[i][k] * B[k][j]) % self.MOD

        return C

    def power(self, base, exp):
        """
        Matrix Exponentiation: base^exp using binary exponentiation
        O(n³ log exp) instead of O(n³ × exp)
        """
        n = len(base)

        # Identity matrix (like number 1 in scalar exponentiation)
        result = [[1 if i == j else 0 for j in range(n)] for i in range(n)]

        while exp:
            if exp & 1:                          # Current bit is 1
                result = self.multiply(result, base)
            base = self.multiply(base, base)     # Square the base
            exp >>= 1                            # Process next bit

        return result

    def zigZagArrays(self, n: int, l: int, r: int) -> int:
        m = r - l + 1    # Total distinct values
        S = 2 * m        # Total states

        # ─── State Encoding ───────────────────────────────────
        def U(v): return v - 1        # UP state   → index [0, m-1]
        def D(v): return m + (v - 1)  # DOWN state → index [m, 2m-1]
        # ──────────────────────────────────────────────────────

        # ─── Build Transition Matrix ──────────────────────────
        T = [[0] * S for _ in range(S)]

        for v in range(1, m + 1):
            # U(v): v came after going UP (v > prev)
            # → next u must be LESS than v (go DOWN)
            for u in range(1, v):
                T[U(v)][D(u)] = 1   # From D(u), reach U(v)

            # D(v): v came after going DOWN (v < prev)
            # → next u must be GREATER than v (go UP)
            for u in range(v + 1, m + 1):
                T[D(v)][U(u)] = 1   # From U(u), reach D(v)
        # ──────────────────────────────────────────────────────

        # ─── Base Case: Length 2 Arrays ───────────────────────
        dp2 = [0] * S
        for v in range(1, m + 1):
            dp2[U(v)] = v - 1   # Choices < v (first element)
            dp2[D(v)] = m - v   # Choices > v (first element)
        # ──────────────────────────────────────────────────────

        if n == 2:
            return sum(dp2) % self.MOD

        # ─── Apply Matrix Exponentiation ──────────────────────
        P = self.power(T, n - 2)   # T^(n-2)

        # Multiply P × dp2
        dpn = [0] * S
        for i in range(S):
            for j in range(S):
                dpn[i] = (dpn[i] + P[i][j] * dp2[j]) % self.MOD
        # ──────────────────────────────────────────────────────

        return sum(dpn) % self.MOD
```

